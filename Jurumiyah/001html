<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes">
  <title>Quiz Al-Ajurumiyah - 60 Soal</title>
  <!-- Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&family=Amiri:wght@400;700&display=swap" rel="stylesheet">
  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Poppins', sans-serif;
      background: linear-gradient(135deg, #1e3c72, #2a5298);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 12px;
    }

    .app-container {
      width: 100%;
      max-width: 600px;
      background: rgba(255,255,255,0.1);
      backdrop-filter: blur(12px);
      border-radius: 32px;
      padding: 20px;
      box-shadow: 0 20px 40px rgba(0,0,0,0.4);
      border: 1px solid rgba(255,255,255,0.2);
    }

    /* Layar Utama */
    .main-menu {
      text-align: center;
      color: white;
      padding: 30px 16px;
    }

    .main-menu h1 {
      font-size: 2.4rem;
      font-weight: 700;
      margin-bottom: 8px;
      text-shadow: 4px 4px 0 #1e2f5a;
      letter-spacing: 1px;
    }

    .main-menu .level-badge {
      background: #f6d365;
      color: #1e3c72;
      font-weight: 600;
      font-size: 1.2rem;
      padding: 8px 30px;
      border-radius: 40px;
      display: inline-block;
      margin: 16px 0 30px;
      box-shadow: 0 8px 0 #b68b40;
    }

    .btn-mulai {
      background: #f6d365;
      border: none;
      color: #1e3c72;
      font-weight: 700;
      font-size: 2rem;
      padding: 18px 50px;
      border-radius: 60px;
      cursor: pointer;
      box-shadow: 0 12px 0 #b68b40, 0 8px 20px rgba(0,0,0,0.3);
      transition: all 0.1s ease;
      font-family: 'Poppins', sans-serif;
      width: 100%;
      max-width: 300px;
    }

    .btn-mulai:active {
      transform: translateY(8px);
      box-shadow: 0 4px 0 #b68b40, 0 8px 20px rgba(0,0,0,0.3);
    }

    /* Layar Quiz */
    .quiz-screen {
      color: white;
    }

    .quiz-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      background: rgba(0,0,0,0.2);
      padding: 12px 20px;
      border-radius: 50px;
      margin-bottom: 20px;
      backdrop-filter: blur(4px);
    }

    .quiz-header .level-small {
      background: #f6d365;
      color: #1e3c72;
      font-weight: 600;
      padding: 6px 16px;
      border-radius: 40px;
      font-size: 0.9rem;
    }

    .quiz-header .progress {
      font-size: 1rem;
      font-weight: 600;
      background: rgba(255,255,255,0.2);
      padding: 6px 16px;
      border-radius: 40px;
    }

    /* Tombol navigasi grid */
    .nav-grid-btn {
      background: rgba(255,255,255,0.2);
      border: none;
      color: white;
      font-size: 1.2rem;
      width: 40px;
      height: 40px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: 0.2s;
    }
    .nav-grid-btn:hover {
      background: rgba(255,255,255,0.4);
    }

    .question-box {
      background: rgba(255,255,255,0.15);
      backdrop-filter: blur(4px);
      border-radius: 28px;
      padding: 24px 18px;
      margin-bottom: 20px;
      border: 1px solid rgba(255,255,255,0.3);
    }

    .question-text {
      font-family: 'Amiri', serif;
      font-size: 1.6rem;
      font-weight: 700;
      line-height: 1.5;
      text-align: center;
      margin-bottom: 24px;
      color: #fff5e0;
      word-break: break-word;
    }

    .options-container {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .option-item {
      background: rgba(255,255,255,0.2);
      border: 2px solid rgba(255,255,255,0.3);
      border-radius: 50px;
      padding: 14px 18px;
      font-family: 'Amiri', serif;
      font-size: 1.2rem;
      color: white;
      cursor: pointer;
      transition: all 0.2s;
      text-align: right;
      direction: rtl;
      display: flex;
      align-items: center;
      gap: 12px;
      width: 100%;
    }

    .option-item:hover:not(.disabled-option) {
      background: rgba(255,255,255,0.35);
      border-color: #f6d365;
    }

    .option-item.selected {
      background: #f6d365;
      color: #1e3c72;
      font-weight: 700;
      border-color: #f6d365;
      box-shadow: 0 0 15px #f6d365;
    }

    .disabled-option {
      pointer-events: none;
      opacity: 0.6;
    }

    .option-prefix {
      background: #1e3c72;
      width: 36px;
      height: 36px;
      border-radius: 50%;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      font-family: 'Poppins', sans-serif;
      color: white;
      flex-shrink: 0;
    }

    .selected .option-prefix {
      background: #b68b40;
    }

    .footer {
      margin-top: 24px;
      text-align: center;
      color: rgba(255,255,255,0.8);
      font-size: 0.9rem;
    }

    /* Notifikasi */
    .notification-overlay {
      position: fixed;
      top: 0; left: 0; width: 100%; height: 100%;
      background: rgba(0,0,0,0.6);
      backdrop-filter: blur(5px);
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 1000;
      padding: 16px;
    }

    .notification-card {
      background: white;
      border-radius: 40px;
      padding: 28px 20px;
      max-width: 450px;
      width: 100%;
      text-align: center;
      box-shadow: 0 30px 50px rgba(0,0,0,0.5);
      animation: pop 0.3s;
    }

    @keyframes pop {
      0% { transform: scale(0.8); opacity: 0; }
      100% { transform: scale(1); opacity: 1; }
    }

    .notification-card.benar {
      background: linear-gradient(145deg, #c8e6c9, #a5d6a7);
      border: 4px solid #2e7d32;
    }

    .notification-card.salah {
      background: linear-gradient(145deg, #ffcdd2, #ef9a9a);
      border: 4px solid #b71c1c;
    }

    .notification-card.selesai {
      background: linear-gradient(145deg, #bbdefb, #90caf9);
      border: 4px solid #1565c0;
    }

    .notif-icon {
      font-size: 4rem;
      margin-bottom: 8px;
    }

    .notif-title {
      font-size: 2.5rem;
      font-weight: 700;
      margin-bottom: 20px;
    }

    .notif-buttons {
      display: flex;
      gap: 12px;
      justify-content: center;
      flex-wrap: wrap;
    }

    .notif-btn {
      border: none;
      padding: 14px 24px;
      font-size: 1.1rem;
      font-weight: 600;
      border-radius: 50px;
      cursor: pointer;
      transition: 0.2s;
      min-width: 130px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      font-family: 'Poppins', sans-serif;
      box-shadow: 0 5px 0 rgba(0,0,0,0.2);
    }

    .notif-btn:active {
      transform: translateY(3px);
      box-shadow: 0 2px 0 rgba(0,0,0,0.2);
    }

    .btn-next {
      background: #2e7d32;
      color: white;
    }

    .btn-ulangi {
      background: #ff9800;
      color: white;
    }

    .btn-penjelasan {
      background: #2196f3;
      color: white;
    }

    .btn-level2 {
      background: #7b1fa2;
      color: white;
    }

    .explanation-box {
      background: #fff3e0;
      border-radius: 24px;
      padding: 18px;
      margin-top: 24px;
      text-align: left;
      color: #1e3c72;
      font-size: 0.95rem;
      max-height: 300px;
      overflow-y: auto;
      border: 2px solid #ffb74d;
      direction: ltr;
    }

    .hidden {
      display: none !important;
    }

    /* Panel navigasi grid */
    .nav-panel-overlay {
      position: fixed;
      top: 0; left: 0; width: 100%; height: 100%;
      background: rgba(0,0,0,0.7);
      backdrop-filter: blur(4px);
      z-index: 1100;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 16px;
    }

    .nav-panel {
      background: #1e3c72;
      border-radius: 40px;
      padding: 24px;
      max-width: 500px;
      width: 100%;
      border: 2px solid #f6d365;
      box-shadow: 0 20px 40px black;
    }

    .nav-panel h3 {
      color: #f6d365;
      text-align: center;
      margin-bottom: 20px;
      font-size: 1.5rem;
    }

    .nav-grid {
      display: grid;
      grid-template-columns: repeat(6, 1fr);
      gap: 10px;
      margin-bottom: 20px;
    }

    .nav-item {
      aspect-ratio: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      background: rgba(255,255,255,0.2);
      border: 2px solid rgba(255,255,255,0.3);
      border-radius: 12px;
      color: white;
      font-weight: 700;
      font-size: 1.1rem;
      cursor: pointer;
      transition: 0.2s;
    }

    .nav-item.answered {
      background: #2e7d32;
      border-color: #81c784;
    }

    .nav-item.unanswered {
      background: #b71c1c;
      border-color: #ff8a80;
    }

    .nav-item:hover {
      transform: scale(1.05);
      border-color: #f6d365;
    }

    .btn-tutup-panel {
      background: #f6d365;
      border: none;
      color: #1e3c72;
      font-weight: 700;
      padding: 12px 30px;
      border-radius: 40px;
      width: 100%;
      cursor: pointer;
      font-size: 1.1rem;
    }
  </style>
</head>
<body>
<div class="app-container" id="appContainer">
  <!-- Layar Utama -->
  <div id="mainMenu" class="main-menu">
    <h1>Quiz Al-Ajurumiyah</h1>
    <div class="level-badge"><i class="fas fa-star"></i> Level 1-3 <i class="fas fa-star"></i></div>
    <button class="btn-mulai" id="btnMulai"><i class="fas fa-play"></i> Mulai</button>
    <div style="margin-top: 30px; font-size: 0.85rem; opacity: 0.8;">60 soal pilihan ganda • bab al-Kalam</div>
  </div>

  <!-- Layar Quiz (awalnya tersembunyi) -->
  <div id="quizScreen" class="quiz-screen hidden">
    <div class="quiz-header">
      <span class="level-small"><i class="fas fa-flag"></i> 60 Soal</span>
      <span class="progress" id="progressIndicator">1/60</span>
      <button class="nav-grid-btn" id="openNavGrid"><i class="fas fa-th"></i></button>
    </div>

    <div class="question-box">
      <div class="question-text" id="questionText">Memuat soal...</div>
      <div class="options-container" id="optionsContainer"></div>
    </div>

    <div class="footer">— ‏شرح الكلام وأقسامه لابن عثيمين ‏—</div>
  </div>
</div>

<!-- Panel Navigasi Grid -->
<div id="navPanelOverlay" class="nav-panel-overlay hidden">
  <div class="nav-panel">
    <h3><i class="fas fa-list"></i> Pilih Soal</h3>
    <div class="nav-grid" id="navGrid"></div>
    <button class="btn-tutup-panel" id="closeNavPanel"><i class="fas fa-times"></i> Tutup</button>
  </div>
</div>

<!-- Notifikasi (popup) -->
<div id="notificationOverlay" class="notification-overlay hidden">
  <div class="notification-card" id="notificationCard">
    <div class="notif-icon" id="notifIcon">✅</div>
    <div class="notif-title" id="notifTitle">Benar</div>
    <div class="notif-buttons" id="notifButtons"></div>
    <div id="explanationArea" class="explanation-box hidden"></div>
  </div>
</div>

<script>
  (function() {
    // ---------- DATA SOAL (60 soal) ----------
    const questions = [
      // Soal 1 (mudah)
      {
        question: "ما تعريف الكلام عند النحويين؟",
        options: ["اللفظ المفيد", "اللفظ المركب المفيد بالوضع", "اللفظ المركب", "ما أفاد معنى"],
        correct: 1,
        explanation: "Analisis: الكلام هو اللفظ المركب المفيد بالوضع. هذه الأربعة قيود لا بد منها: اللفظ، التركيب، الإفادة، والوضع العربي."
      },
      // Soal 2 (mudah)
      {
        question: "كم أقسام الكلام عند النحويين؟",
        options: ["قسمان", "ثلاثة", "أربعة", "خمسة"],
        correct: 1,
        explanation: "Analisis: أقسام الكلام ثلاثة: اسم وفعل وحرف جاء لمعنى."
      },
      // Soal 3 (mudah)
      {
        question: "أي من التالي ليس من علامات الاسم؟",
        options: ["الخفض", "التنوين", "تاء التأنيث الساكنة", "دخول الألف واللام"],
        correct: 2,
        explanation: "Analisis: تاء التأنيث الساكنة من علامات الفعل. علامات الاسم: الخفض، التنوين، دخول الألف واللام، وحروف الخفض."
      },
      // Soal 4 (mudah)
      {
        question: "كم عدد حروف الخفض التي ذكرها المؤلف؟",
        options: ["سبعة", "ثمانية", "تسعة", "عشرة"],
        correct: 2,
        explanation: "Analisis: حروف الخفض تسعة: من، إلى، عن، على، في، رب، الباء، الكاف، اللام."
      },
      // Soal 5 (mudah)
      {
        question: "ما معنى 'المفيد' في تعريف الكلام؟",
        options: ["ما كان طويلاً", "ما أفاد السامع بحيث لا يتشوف بعده إلى غيره", "ما كان مفهومًا", "ما كان عربياً"],
        correct: 1,
        explanation: "Analisis: المفيد هو ما أفاد السامع فائدة يحسن السكوت عليها ولا يتشوف بعدها إلى شيء."
      },
      // Soal 6 (mudah)
      {
        question: "أي من التالي يعتبر كلامًا عند النحويين؟",
        options: ["الإشارة باليد", "الكتابة على الورق", "قول 'قام زيد'", "الإيماء بالرأس"],
        correct: 2,
        explanation: "Analisis: الكلام عند النحويين لا بد أن يكون لفظًا، فالإشارة والكتابة لا تسمى كلامًا."
      },
      // Soal 7 (mudah)
      {
        question: "'قد' من علامات أي قسم؟",
        options: ["الاسم", "الفعل", "الحرف", "الاسم والفعل معًا"],
        correct: 1,
        explanation: "Analisis: 'قد' من علامات الفعل، تدخل على الماضي والمضارع."
      },
      // Soal 8 (mudah)
      {
        question: "حروف القسم هي:",
        options: ["الواو والباء والتاء", "من وإلى وعن", "في ورب والكاف", "اللام والباء والكاف"],
        correct: 0,
        explanation: "Analisis: حروف القسم: الواو، الباء، التاء."
      },
      // Soal 9 (mudah)
      {
        question: "ماذا يسمى الخفض عند البصريين؟",
        options: ["الخفض", "الجر", "الإعراب", "الإضافة"],
        correct: 1,
        explanation: "Analisis: البصريون يعبرون عن الخفض بالجر، والكوفيون يقولون خفض."
      },
      // Soal 10 (mudah)
      {
        question: "'رب' من حروف:",
        options: ["القسم فقط", "الخفض فقط", "الخفض والقسم معًا", "النصب"],
        correct: 1,
        explanation: "Analisis: 'رب' من حروف الخفض وليست من حروف القسم."
      },
      // Soal 11 (mudah)
      {
        question: "ما علامة الحرف عند النحويين؟",
        options: ["دخول الألف واللام", "قبول التنوين", "عدم قبول علامات الاسم والفعل", "دخول حروف الجر"],
        correct: 2,
        explanation: "Analisis: الحرف هو ما لا يصلح معه دليل الاسم ولا دليل الفعل."
      },
      // Soal 12 (mudah)
      {
        question: "'السين' و'سوف' تدخلان على:",
        options: ["الاسم", "الفعل الماضي", "الفعل المضارع", "الحرف"],
        correct: 2,
        explanation: "Analisis: السين وسوف تختصان بالفعل المضارع."
      },
      // Soal 13 (mudah)
      {
        question: "'تاء التأنيث الساكنة' تختص بـ:",
        options: ["الاسم", "الفعل الماضي", "الفعل المضارع", "الحرف"],
        correct: 1,
        explanation: "Analisis: تاء التأنيث الساكنة تختص بالفعل الماضي، مثل 'قالت'."
      },
      // Soal 14 (mudah)
      {
        question: "مثال على الكلمة التي فيها علامة الخفض فقط:",
        options: ["رجلٌ", "الكتابُ", "بزيدٍ", "يكتبُ"],
        correct: 2,
        explanation: "Analisis: 'بزيد'، كلمة 'زيد' مجرورة بالباء، وهذا يدل على أنها اسم."
      },
      // Soal 15 (mudah)
      {
        question: "'من' حرف جر يفيد:",
        options: ["الانتهاء", "الابتداء", "الاستعلاء", "التشبيه"],
        correct: 1,
        explanation: "Analisis: 'من' للابتداء، مثل 'خرجت من البصرة'."
      },
      // Soal 16 (mudah)
      {
        question: "'إلى' حرف جر يفيد:",
        options: ["الابتداء", "الانتهاء", "الاستعلاء", "الظرفية"],
        correct: 1,
        explanation: "Analisis: 'إلى' للانتهاء، مثل 'خرجت من مكة إلى المدينة'."
      },
      // Soal 17 (mudah)
      {
        question: "'على' حرف جر يفيد:",
        options: ["الابتداء", "الانتهاء", "الاستعلاء", "التبعية"],
        correct: 2,
        explanation: "Analisis: 'على' للاستعلاء، مثل 'على السطح'."
      },
      // Soal 18 (mudah)
      {
        question: "الكاف من حروف الخفض وتفيد:",
        options: ["الاستعلاء", "التشبيه", "الظرفية", "القسم"],
        correct: 1,
        explanation: "Analisis: الكاف تفيد التشبيه، مثل 'فلان كالبحر'."
      },
      // Soal 19 (mudah)
      {
        question: "أي من التالية ليست من حروف القسم؟",
        options: ["الواو", "الباء", "التاء", "الكاف"],
        correct: 3,
        explanation: "Analisis: حروف القسم هي الواو والباء والتاء فقط."
      },
      // Soal 20 (mudah)
      {
        question: "'ال' التي للتعريف تدخل على:",
        options: ["الأفعال فقط", "الأسماء فقط", "الحروف فقط", "الأسماء والأفعال"],
        correct: 1,
        explanation: "Analisis: الألف واللام من علامات الاسم، فلا تدخل إلا على الأسماء."
      },
      // Soal 21 (sedang)
      {
        question: "ما الدليل على أن أقسام الكلام ثلاثة؟",
        options: ["القرآن الكريم", "السنة النبوية", "الإجماع والقياس", "التتبع والاستقراء"],
        correct: 3,
        explanation: "Analisis: دليل هذا التقسيم هو التتبع والاستقراء لكلام العرب."
      },
      // Soal 22 (sedang)
      {
        question: "'إن اجتهدت' هل تعتبر كلامًا عند النحويين؟",
        options: ["نعم، لأنه مركب من كلمتين", "لا، لأنه غير مفيد", "نعم، لأنه لفظ", "لا، لأنه ليس بالوضع العربي"],
        correct: 1,
        explanation: "Analisis: 'إن اجتهدت' مركب لكنه غير مفيد، لأن السامع يتشوف إلى جواب الشرط."
      },
      // Soal 23 (sedang)
      {
        question: "أي العلامات الأربع للاسم لا يمكن اجتماعها مع التنوين؟",
        options: ["الخفض", "دخول الألف واللام", "حروف الخفض", "حروف القسم"],
        correct: 1,
        explanation: "Analisis: التنوين والألف واللام لا يجتمعان أبدًا."
      },
      // Soal 24 (sedang)
      {
        question: "كم يصبح عدد حروف الخفض إذا أضفنا حروف القسم إليها؟",
        options: ["9 أحرف", "10 أحرف", "11 حرفًا", "12 حرفًا"],
        correct: 3,
        explanation: "Analisis: حروف الخفض 9 + حروف القسم 3 = 12، مع ملاحظة أن الباء مشتركة."
      },
      // Soal 25 (sedang)
      {
        question: "لماذا لا تعتبر 'شجرة' فعلاً مع وجود تاء التأنيث؟",
